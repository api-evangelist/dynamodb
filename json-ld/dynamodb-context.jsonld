    "StreamSpecification": {
      "@id": "dynamodb:API_StreamSpecification.html",
      "@context": {
        "streamEnabled": {
          "@id": "dynamodb:API_StreamSpecification.html#DDB-Type-StreamSpecification-StreamEnabled",
          "@type": "xsd:boolean"
        },
        "streamViewType": {
          "@id": "dynamodb:API_StreamSpecification.html#DDB-Type-StreamSpecification-StreamViewType",
          "@type": "xsd:string"
        }
      }
    },

    "StreamRecord": {
      "@id": "dynamodb:API_Record.html",
      "@context": {
        "eventID": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        },
        "eventName": {
          "@id": "dynamodb:API_Record.html#DDB-Type-Record-eventName",
          "@type": "xsd:string"
        },
        "eventVersion": {
          "@id": "schema:version",
          "@type": "xsd:string"
        },
        "eventSource": {
          "@id": "schema:source",
          "@type": "xsd:string"
        },
        "awsRegion": {
          "@id": "cloud:region",
          "@type": "xsd:string"
        },
        "eventSourceARN": {
          "@id": "cloud:resourceArn",
          "@type": "@id"
        },
        "dynamodb": {
          "@id": "dynamodb:API_StreamRecord.html",
          "@context": {
            "approximateCreationDateTime": {
              "@id": "schema:dateCreated",
              "@type": "xsd:integer"
            },
            "keys": {
              "@id": "dynamodb:API_StreamRecord.html#DDB-Type-StreamRecord-Keys",
              "@container": "@index"
            },
            "newImage": {
              "@id": "dynamodb:API_StreamRecord.html#DDB-Type-StreamRecord-NewImage",
              "@container": "@index"
            },
            "oldImage": {
              "@id": "dynamodb:API_StreamRecord.html#DDB-Type-StreamRecord-OldImage",
              "@container": "@index"
            },
            "sequenceNumber": {
              "@id": "dynamodb:API_StreamRecord.html#DDB-Type-StreamRecord-SequenceNumber",
              "@type": "xsd:string"
            },
            "sizeBytes": {
              "@id": "schema:contentSize",
              "@type": "xsd:integer"
            },
            "streamViewType": {
              "@id": "dynamodb:API_StreamRecord.html#DDB-Type-StreamRecord-StreamViewType",
              "@type": "xsd:string"
            }
          }
        }
      }
    },

    "ConsumedCapacity": {
      "@id": "dynamodb:API_ConsumedCapacity.html",
      "@context": {
        "tableName": {
          "@id": "dynamodb:API_ConsumedCapacity.html#DDB-Type-ConsumedCapacity-TableName",
