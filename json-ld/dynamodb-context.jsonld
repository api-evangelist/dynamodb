        },
        "backupCreationDateTime": {
          "@id": "schema:dateCreated",
          "@type": "xsd:dateTime"
        },
        "backupExpiryDateTime": {
          "@id": "schema:expires",
          "@type": "xsd:dateTime"
        }
      }
