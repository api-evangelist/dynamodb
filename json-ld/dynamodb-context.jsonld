{
  "@context": {
    "@version": 1.1,

    "dynamodb": "https://docs.aws.amazon.com/amazondynamodb/latest/APIReference/",
    "aws": "https://aws.amazon.com/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "dcterms": "http://purl.org/dc/terms/",
    "cloud": "https://schema.apis.io/cloud/",

    "DynamoDBTable": {
      "@id": "dynamodb:API_CreateTable.html",
      "@context": {
        "tableName": {
          "@id": "dynamodb:API_CreateTable.html#DDB-CreateTable-request-TableName",
          "@type": "xsd:string"
        },
        "tableArn": {
          "@id": "cloud:resourceArn",
          "@type": "@id"
        },
        "tableId": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        },
        "tableStatus": {
          "@id": "dynamodb:API_TableDescription.html#DDB-Type-TableDescription-TableStatus",
          "@type": "xsd:string"
        },
        "tableClass": {
          "@id": "dynamodb:API_TableClassSummary.html",
          "@type": "xsd:string"
        },
        "creationDateTime": {
          "@id": "schema:dateCreated",
          "@type": "xsd:dateTime"
        },
        "tableSizeBytes": {
          "@id": "schema:contentSize",
          "@type": "xsd:integer"
        },
        "itemCount": {
          "@id": "schema:numberOfItems",
          "@type": "xsd:integer"
        },
        "billingMode": {
          "@id": "dynamodb:API_BillingModeSummary.html",
          "@type": "xsd:string"
        },
        "deletionProtectionEnabled": {
          "@id": "dynamodb:API_TableDescription.html#DDB-Type-TableDescription-DeletionProtectionEnabled",
          "@type": "xsd:boolean"
        }
      }
    },

    "DynamoDBItem": {
      "@id": "dynamodb:API_PutItem.html",
      "@context": {
        "attributes": {
          "@id": "dynamodb:API_AttributeValue.html",
          "@container": "@index"
        }
      }
    },

    "AttributeValue": {
      "@id": "dynamodb:API_AttributeValue.html",
      "@context": {
        "S": {
          "@id": "dynamodb:API_AttributeValue.html#DDB-Type-AttributeValue-S",
          "@type": "xsd:string"
        },
        "N": {
          "@id": "dynamodb:API_AttributeValue.html#DDB-Type-AttributeValue-N",
          "@type": "xsd:string"
        },
        "B": {
          "@id": "dynamodb:API_AttributeValue.html#DDB-Type-AttributeValue-B",
          "@type": "xsd:base64Binary"
        },
        "SS": {
          "@id": "dynamodb:API_AttributeValue.html#DDB-Type-AttributeValue-SS",
          "@container": "@set"
        },
        "NS": {
          "@id": "dynamodb:API_AttributeValue.html#DDB-Type-AttributeValue-NS",
          "@container": "@set"
        },
        "BS": {
          "@id": "dynamodb:API_AttributeValue.html#DDB-Type-AttributeValue-BS",
          "@container": "@set"
        },
        "M": {
          "@id": "dynamodb:API_AttributeValue.html#DDB-Type-AttributeValue-M",
          "@container": "@index"
        },
        "L": {
          "@id": "dynamodb:API_AttributeValue.html#DDB-Type-AttributeValue-L",
          "@container": "@list"
        },
        "NULL": {
          "@id": "dynamodb:API_AttributeValue.html#DDB-Type-AttributeValue-NULL",
          "@type": "xsd:boolean"
        },
        "BOOL": {
          "@id": "dynamodb:API_AttributeValue.html#DDB-Type-AttributeValue-BOOL",
          "@type": "xsd:boolean"
        }
      }
    },

    "KeySchema": {
      "@id": "dynamodb:API_KeySchemaElement.html",
      "@context": {
        "attributeName": {
          "@id": "dynamodb:API_KeySchemaElement.html#DDB-Type-KeySchemaElement-AttributeName",
