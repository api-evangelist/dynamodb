          "@type": "xsd:double"
        },
        "writeCapacityUnits": {
          "@id": "dynamodb:API_ConsumedCapacity.html#DDB-Type-ConsumedCapacity-WriteCapacityUnits",
          "@type": "xsd:double"
        }
      }
    },

    "TimeToLiveSpecification": {
      "@id": "dynamodb:API_TimeToLiveSpecification.html",
      "@context": {
        "enabled": {
          "@id": "dynamodb:API_TimeToLiveSpecification.html#DDB-Type-TimeToLiveSpecification-Enabled",
