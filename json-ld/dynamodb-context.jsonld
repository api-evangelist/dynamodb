          "@id": "schema:contentSize",
          "@type": "xsd:integer"
        },
        "itemCount": {
          "@id": "schema:numberOfItems",
          "@type": "xsd:integer"
        },
        "keySchema": {
          "@id": "dynamodb:API_LocalSecondaryIndex.html#DDB-Type-LocalSecondaryIndex-KeySchema",
