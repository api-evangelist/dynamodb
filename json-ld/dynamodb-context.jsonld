        "key": {
          "@id": "dynamodb:API_Tag.html#DDB-Type-Tag-Key",
          "@type": "xsd:string"
        },
        "value": {
          "@id": "dynamodb:API_Tag.html#DDB-Type-Tag-Value",
          "@type": "xsd:string"
        }
      }
    },

