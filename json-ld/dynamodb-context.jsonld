    "ProvisionedThroughput": {
      "@id": "dynamodb:API_ProvisionedThroughput.html",
      "@context": {
        "readCapacityUnits": {
          "@id": "dynamodb:API_ProvisionedThroughput.html#DDB-Type-ProvisionedThroughput-ReadCapacityUnits",
          "@type": "xsd:integer"
        },
        "writeCapacityUnits": {
          "@id": "dynamodb:API_ProvisionedThroughput.html#DDB-Type-ProvisionedThroughput-WriteCapacityUnits",
          "@type": "xsd:integer"
        }
      }
