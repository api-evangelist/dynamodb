          "@id": "schema:startDate",
          "@type": "xsd:dateTime"
        },
        "latestRestorableDateTime": {
          "@id": "schema:endDate",
          "@type": "xsd:dateTime"
        }
      }
    },

    "ExportDescription": {
      "@id": "dynamodb:API_ExportDescription.html",
      "@context": {
        "exportArn": {
          "@id": "cloud:resourceArn",
          "@type": "@id"
        },
        "exportStatus": {
