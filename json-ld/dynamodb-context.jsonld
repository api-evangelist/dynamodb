    "GlobalSecondaryIndex": {
      "@id": "dynamodb:API_GlobalSecondaryIndex.html",
      "@context": {
        "indexName": {
          "@id": "dynamodb:API_GlobalSecondaryIndex.html#DDB-Type-GlobalSecondaryIndex-IndexName",
          "@type": "xsd:string"
        },
        "indexStatus": {
          "@id": "dynamodb:API_GlobalSecondaryIndexDescription.html#DDB-Type-GlobalSecondaryIndexDescription-IndexStatus",
          "@type": "xsd:string"
        },
        "indexArn": {
          "@id": "cloud:resourceArn",
          "@type": "@id"
        },
        "indexSizeBytes": {
          "@id": "schema:contentSize",
          "@type": "xsd:integer"
        },
        "itemCount": {
          "@id": "schema:numberOfItems",
          "@type": "xsd:integer"
        },
        "keySchema": {
          "@id": "dynamodb:API_GlobalSecondaryIndex.html#DDB-Type-GlobalSecondaryIndex-KeySchema",
          "@container": "@list"
        },
        "projection": {
          "@id": "dynamodb:API_Projection.html"
        },
        "provisionedThroughput": {
          "@id": "dynamodb:API_ProvisionedThroughput.html"
        }
      }
    },

    "LocalSecondaryIndex": {
      "@id": "dynamodb:API_LocalSecondaryIndex.html",
      "@context": {
        "indexName": {
          "@id": "dynamodb:API_LocalSecondaryIndex.html#DDB-Type-LocalSecondaryIndex-IndexName",
