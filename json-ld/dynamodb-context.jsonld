    "SSESpecification": {
      "@id": "dynamodb:API_SSESpecification.html",
      "@context": {
        "enabled": {
          "@id": "dynamodb:API_SSESpecification.html#DDB-Type-SSESpecification-Enabled",
          "@type": "xsd:boolean"
        },
        "sseType": {
          "@id": "dynamodb:API_SSESpecification.html#DDB-Type-SSESpecification-SSEType",
          "@type": "xsd:string"
        },
        "kmsMasterKeyId": {
          "@id": "dynamodb:API_SSESpecification.html#DDB-Type-SSESpecification-KMSMasterKeyId",
          "@type": "xsd:string"
        }
      }
